rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/products/{productId}
    // Fields:
    //   - userId: string (required)
    //   - name: string (required, 2-100 chars)
    //   - notes: string (optional)
    //   - stores: list of maps (required, max 5)
    //   - createdAt: timestamp (required)
    //   - cheapestPrice: number (optional)
    //   - cheapestStore: string (optional)
    //   - priceHistory: list of maps (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "syedakiswa650@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['userId', 'name', 'stores', 'createdAt']) &&
             data.userId is string &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.stores is list && data.stores.size() <= 5 &&
             data.createdAt is timestamp &&
             (data.notes == null || (data.notes is string && data.notes.size() <= 500));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);

      match /products/{productId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidProduct(request.resource.data) && request.resource.data.userId == userId;
        allow update: if (isOwner(userId) && isValidProduct(request.resource.data) && request.resource.data.userId == userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
